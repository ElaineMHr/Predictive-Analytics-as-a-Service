FROM node:25-alpine
WORKDIR /app
COPY ./frontend .
RUN rm -rf ./node_modules
RUN npm install

# Bake env vars into the static build at build time
ARG VITE_API_URL=http://localhost:42000
ARG VITE_PROGRESS_MODE=poll
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_PROGRESS_MODE=$VITE_PROGRESS_MODE

RUN npm run build
RUN npm i -g serve
EXPOSE 3000
CMD [ "serve", "-s", "dist" ]
