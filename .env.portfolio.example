# .env.portfolio.example
# Copy to .env and fill in values before deploying.
# Used by the lightweight-deploy branch (portfolio mode).

# ── App mode ────────────────────────────────────────────
APP_MODE=portfolio

# ── Database (PostgreSQL) ────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Storage (ephemeral — files lost on container restart) ─
MODEL_BASE_PATH=/tmp/models
UPLOAD_DIR=/tmp/uploads

# ── CORS ─────────────────────────────────────────────────
# Set to your frontend URL in production, e.g. https://yourapp.vercel.app
ALLOWED_ORIGINS=*

# ── Seed data ────────────────────────────────────────────
# Set to true on first deploy to populate demo datasets/models
SEED_TEST_DATA=false

# ── Frontend (set these when building the React app) ──────
# VITE_API_URL=https://your-backend.onrender.com
# VITE_PROGRESS_MODE=poll
